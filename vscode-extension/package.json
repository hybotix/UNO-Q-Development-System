{
  "name": "hybx-dev",
  "displayName": "HybX Development System",
  "description": "Hybrid RobotiX — HybX Development System integration for VSCode",
  "version": "0.1.1",
  "publisher": "hybridrobotix",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/hybotix/HybX-Development-System.git"
  },
  "homepage": "https://github.com/hybotix/HybX-Development-System",
  "bugs": {
    "url": "https://github.com/hybotix/HybX-Development-System/issues"
  },
  "contributes": {
    "configuration": {
      "title": "HybX Development System",
      "properties": {
        "hybxDev.sshHost": {
          "type": "string",
          "default": "arduino@unoq.local",
          "description": "SSH connection string for the board (user@host)"
        },
        "hybxDev.appsPath": {
          "type": "string",
          "default": "~/Arduino",
          "description": "Path to the Arduino apps directory on the board"
        },
        "hybxDev.sshKeyPath": {
          "type": "string",
          "default": "",
          "description": "Path to SSH private key (leave empty to use default)"
        },
        "hybxDev.sshPath": {
          "type": "string",
          "default": "/usr/bin/ssh",
          "description": "Full path to the ssh binary (default: /usr/bin/ssh)"
        }
      }
    },
    "commands": [
      {
        "command": "hybxDev.connect",
        "title": "HybX: Connect"
      },
      {
        "command": "hybxDev.start",
        "title": "HybX: Start App"
      },
      {
        "command": "hybxDev.stop",
        "title": "HybX: Stop App"
      },
      {
        "command": "hybxDev.restart",
        "title": "HybX: Restart App"
      },
      {
        "command": "hybxDev.logs",
        "title": "HybX: Show Logs"
      },
      {
        "command": "hybxDev.build",
        "title": "HybX: Build Sketch"
      },
      {
        "command": "hybxDev.addlib",
        "title": "HybX: Add Library"
      },
      {
        "command": "hybxDev.listApps",
        "title": "HybX: List Apps"
      },
      {
        "command": "hybxDev.clean",
        "title": "HybX: Clean"
      },
      {
        "command": "hybxDev.newrepo",
        "title": "HybX: Run newrepo (Bootstrap)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.0.0"
  }
}